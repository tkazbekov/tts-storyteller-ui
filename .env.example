# Base URL of the TTS Storyteller API as reachable FROM THE BROWSER.
# Leave unset to use the /api rewrite (the Next server proxies to API_URL).
# Setting this makes the browser call the backend directly (requires CORS).
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Base URL of the API as reachable FROM THE NEXT SERVER (rewrite target and
# server-component fetches). Defaults to http://localhost:8000.
# NOTE: the /api rewrite target is baked in at BUILD time — for production
# (`next build` + `next start`), API_URL must be set when building.
# Server-component fetches read it at runtime.
# API_URL=http://localhost:8000
